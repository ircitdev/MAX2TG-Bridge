# Max credentials (DevTools → Application → Local Storage → web.max.ru)
MAX_TOKEN=your___oneme_auth_value
MAX_DEVICE_ID=your___oneme_device_id_value
# (Optional) Max chat IDs to listen, comma-separated. Leave unset to listen to all chats.
# MAX_CHAT_IDS=-123,-456

# Telegram bot token (get from @BotFather)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ID of the Telegram SUPERGROUP with Topics (forum) enabled.
# The bot must be an admin there with the "Manage Topics" permission.
# It is a negative number, e.g. -1001234567890.
# Each Max chat gets its own auto-created topic inside this supergroup.
TG_CHAT_ID=-1001234567890

# (Optional) Restrict who may reply back to Max — your Telegram user ID (@userinfobot).
# If unset, anyone in the supergroup can send replies.
# TG_ALLOWED_USER_ID=123456789

# (Optional) SOCKS5 proxy for Telegram (e.g. socks5://user:pass@host:port)
# TG_PROXY=socks5://127.0.0.1:1080

# (Optional) Directory for persistent state (topic mapping). Default: state
# STATE_DIR=state

# Debug mode: verbose logs + JSON dump to debug/ (true/false)
DEBUG=false

# Allow replies from Telegram topics back to Max (true/false)
REPLY_ENABLED=true
